# Base de datos (SQLite local por defecto)
# Para Turso, cambia a: libsql://<tu-db>.turso.io?authToken=<token>
DATABASE_URL="file:./dev.db"

# === Variables opcionales para producción ===

# Turso (base de datos en la nube)
# TURSO_DATABASE_URL="libsql://coachfit-<user>.turso.io"
# TURSO_AUTH_TOKEN="<tu-token-de-turso>"

# La configuración de la IA se carga automáticamente desde /etc/.z-ai-config
# Si necesitas override, crea .z-ai-config con:
# {
#   "baseUrl": "https://internal-api.z.ai/v1",
#   "apiKey": "Z.ai"
# }
