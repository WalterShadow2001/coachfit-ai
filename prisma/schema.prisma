// CoachFit AI - Esquema de base de datos
// Compatible con Turso (libsql) y SQLite local
// Para modo offline-first en APK, usar SQLite local y sincronizar con Turso

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Usamos sqlite como provider en schema, pero en runtime usamos el adapter de libsql
  // Esto permite funcionar tanto con SQLite local como con Turso
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Cuentas de usuario (autenticación con email/password)
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String   // bcrypt hash
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relación 1:1 con UserProfile
  profile      UserProfile?
}

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  name            String
  age             Int
  gender          String   // "male" | "female" | "other"
  heightCm        Float
  weightKg        Float
  targetWeightKg  Float
  activityLevel   String   // "sedentary" | "light" | "moderate" | "active"
  budgetPerWeek   Float    // presupuesto semanal en MXN
  // Horarios base (defaults, overrideados por WorkSchedule)
  wakeTime        String   // "07:00"
  sleepTime       String   // "23:00"
  restrictions    String   // JSON: dietary restrictions
  allergies       String   // JSON
  dislikedFoods   String   // JSON
  equipment       String   // JSON: ["dumbbells","resistance_band","none"]
  goal            String   // "lose" | "maintain" | "gain"
  // Condiciones médicas
  medicalConditions String  @default("[]") // JSON: ["diabetes_type_1", "diabetes_type_2", "bariatric", "hypertension", "hypothyroidism", "pcos", "none"]
  medicalNotes    String?  // Notas adicionales del usuario sobre su salud
  // Ubicación del usuario (para precios locales)
  city            String?  // "Monterrey", "CDMX", etc.
  state           String?  // "Nuevo León"
  country         String   @default("México")
  latitude        Float?
  longitude       Float?
  locationDetected Boolean @default(false)
  // Meta de tiempo para perder/ganar peso
  targetWeeks     Int?     // cuántas semanas para llegar a la meta
  targetDate      DateTime? // fecha objetivo calculada
  // Conexiones de salud
  samsungHealthConnected Boolean @default(false)
  samsungHealthLastSync  DateTime?
  googleFitConnected     Boolean @default(false)
  googleFitLastSync      DateTime?
  googleFitAccessToken   String?
  googleFitRefreshToken  String?
  googleFitTokenExpiry   Int?
  // Configuración de monitoreo
  heartRateMonitoring    Boolean @default(false) // monitoreo continuo de FC
  // Campos para sincronización
  syncStatus      String   @default("synced")
  lastModified    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules       WorkSchedule[]
}

model WorkSchedule {
  id           String   @id @default(cuid())
  profileId    String
  label        String   // "Trabajo L-V", "Sábado", "Domingo Iglesia"
  days         String   // JSON: ["mon","tue","wed","thu","fri"]
  workStart    String   // "09:00"
  workEnd      String   // "18:00"
  lunchStart   String   // "14:00"
  lunchEnd     String   // "15:00"
  // Si es "día libre" (no trabajo, pero define horario distinto)
  isFreeDay    Boolean  @default(false)
  // Notas del usuario
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile      UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model MealPlan {
  id           String   @id @default(cuid())
  weekStart    DateTime
  weekEnd      DateTime
  content      String   // JSON: full plan
  generatedFor String   // user profile snapshot
  syncStatus   String   @default("synced")
  createdAt    DateTime @default(now())
}

model ExercisePlan {
  id           String   @id @default(cuid())
  weekStart    DateTime
  weekEnd      DateTime
  content      String   // JSON: full routine
  syncStatus   String   @default("synced")
  createdAt    DateTime @default(now())
}

model MealLog {
  id           String   @id @default(cuid())
  type         String   // "breakfast" | "lunch" | "dinner" | "snack"
  plannedName  String?
  actualName   String
  calories     Int?
  notes        String?
  loggedAt     DateTime @default(now())
  onPlan       Boolean?
  syncStatus   String   @default("pending")
  source       String   @default("manual") // "manual" | "voice" | "samsung_health"
}

model ExerciseLog {
  id           String   @id @default(cuid())
  plannedName  String?
  actualName   String
  durationMin  Int
  intensity    String?  // "low" | "medium" | "high"
  caloriesBurn Int?
  notes        String?
  loggedAt     DateTime @default(now())
  onPlan       Boolean?
  syncStatus   String   @default("pending")
  source       String   @default("manual") // "manual" | "voice" | "samsung_health"
}

model Notification {
  id           String   @id @default(cuid())
  type         String   // "meal" | "exercise" | "reminder" | "feedback"
  title        String
  body         String
  scheduledFor DateTime
  status       String   @default("pending") // "pending" | "snoozed" | "acknowledged"
  snoozeUntil  DateTime?
  retryCount   Int      @default(0)
  payload      String?  // JSON with extra data
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Feedback {
  id           String   @id @default(cuid())
  date         DateTime
  content      String   // markdown feedback
  score        Int?     // 0-100 adherence
  syncStatus   String   @default("synced")
  createdAt    DateTime @default(now())
}

model Settings {
  id                   String   @id @default("default")
  notificationsEnabled Boolean  @default(true)
  snoozeMinutes        Int      @default(15)
  maxRetries           Int      @default(5)
  retryIntervalMin     Int      @default(10)
  quietHoursStart      String   @default("22:00")
  quietHoursEnd        String   @default("07:00")
  // Sync settings
  cloudSyncEnabled     Boolean  @default(false)
  lastSyncAt           DateTime?
  updatedAt            DateTime @updatedAt
}

// Datos sincronizados desde Samsung Health / Health Connect / Google Fit
model HealthData {
  id           String   @id @default(cuid())
  date         DateTime // día
  steps        Int      @default(0)
  caloriesBurned Int    @default(0) // kcal activas
  caloriesResting Int   @default(0) // kcal en reposo
  distanceMeters Float  @default(0) // metros caminados/corridos
  activeMinutes Int     @default(0) // minutos de actividad moderada+
  heartRateAvg Int?     // bpm promedio
  heartRateMax Int?
  sleepHours   Float?   // horas de sueño
  // Ejercicios específicos (JSON array)
  exercises    String   @default("[]") // [{name, type, duration, calories, startTime, endTime}]
  // Sync metadata
  source       String   @default("samsung_health") // "samsung_health" | "google_fit" | "health_connect" | "manual"
  syncStatus   String   @default("pending")
  syncedAt     DateTime @default(now())

  @@unique([date])
  @@index([date])
}

// Muestras de ritmo cardíaco en tiempo real (para monitoreo continuo)
model HeartRateSample {
  id           String   @id @default(cuid())
  bpm          Int      // latidos por minuto
  timestamp    DateTime @default(now())
  source       String   @default("samsung_health") // "samsung_health" | "google_fit" | "manual" | "bluetooth"

  @@index([timestamp])
}

// Sesiones de ejercicio con GPS (correr, ciclismo, caminata)
model ExerciseSession {
  id           String   @id @default(cuid())
  type         String   // "running" | "cycling" | "walking" | "hiking"
  name         String?
  startTime    DateTime
  endTime      DateTime?
  durationMin  Int      @default(0)
  caloriesBurn Int      @default(0)
  distanceMeters Float  @default(0)
  avgPace      String?  // "5:30 /km"
  avgHeartRate Int?
  maxHeartRate Int?
  // Ruta GPS como array de puntos
  route        String   @default("[]") // JSON: [{lat, lng, timestamp, altitude, speed, accuracy}]
  // Estado
  status       String   @default("active") // "active" | "paused" | "finished" | "discarded"
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([startTime])
  @@index([status])
}

// Precios locales de productos (consultados por IA según ubicación del usuario)
model LocalPrice {
  id           String   @id @default(cuid())
  productName  String   // "Pechuga de pollo 1kg", "Huevo 12pz", etc.
  category     String   // "Proteínas", "Verduras", "Granos", "Lácteos", "Frutas"
  price        Float    // MXN
  store        String?  // "Alsuper", "Ahorrera", "Soriana", "Mercado", "Walmart", etc.
  city         String
  state        String?
  unit         String?  // "kg", "pz", "lt", "g"
  // Metadata
  source       String   @default("ai_estimate") // "ai_estimate" | "user_input" | "scraped"
  confidence   Float    @default(0.7) // 0-1 qué tan seguro está la IA
  lastChecked  DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([city, productName])
  @@index([category])
}
